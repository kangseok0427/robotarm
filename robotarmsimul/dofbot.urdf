<?xml version="1.0"?>
<robot name="dofbot">

  <!-- 베이스 -->
  <link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.05" length="0.04"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.05" length="0.04"/></geometry>
    </collision>
  </link>

  <!-- Joint 1: 베이스 회전 (Y축, 0~180도) -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.02"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="3.14159" effort="10" velocity="1"/>
  </joint>

  <link name="link1">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry><cylinder radius="0.03" length="0.1"/></geometry>
      <material name="white"><color rgba="0.9 0.9 0.9 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.05"/>
      <geometry><cylinder radius="0.03" length="0.1"/></geometry>
    </collision>
  </link>

  <!-- Joint 2: 앞뒤 (0~180도) -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.1"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="3.14159" effort="10" velocity="1"/>
  </joint>

  <link name="link2">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.1"/>
      <geometry><cylinder radius="0.025" length="0.2"/></geometry>
      <material name="white"><color rgba="0.9 0.9 0.9 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1"/>
      <geometry><cylinder radius="0.025" length="0.2"/></geometry>
    </collision>
  </link>

  <!-- Joint 3: 앞뒤 (0~180도) -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.2"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="3.14159" effort="10" velocity="1"/>
  </joint>

  <link name="link3">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.075"/>
      <geometry><cylinder radius="0.02" length="0.15"/></geometry>
      <material name="white"><color rgba="0.9 0.9 0.9 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.075"/>
      <geometry><cylinder radius="0.02" length="0.15"/></geometry>
    </collision>
  </link>

  <!-- Joint 4: 앞뒤 (0~180도) -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 0.15"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="3.14159" effort="10" velocity="1"/>
  </joint>

  <link name="link4">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry><cylinder radius="0.02" length="0.1"/></geometry>
      <material name="white"><color rgba="0.9 0.9 0.9 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.05"/>
      <geometry><cylinder radius="0.02" length="0.1"/></geometry>
    </collision>
  </link>

  <!-- Joint 5: 손목 비틀기 (0~270도) -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 0.1"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="4.71239" effort="10" velocity="1"/>
  </joint>

  <link name="link5">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.03"/>
      <geometry><cylinder radius="0.015" length="0.06"/></geometry>
      <material name="white"><color rgba="0.9 0.9 0.9 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.03"/>
      <geometry><cylinder radius="0.015" length="0.06"/></geometry>
    </collision>
  </link>

  <!-- Joint 6: 집게 (0~180도) -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="gripper"/>
    <origin xyz="0 0 0.06"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="3.14159" effort="5" velocity="1"/>
  </joint>

  <link name="gripper">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.02"/>
      <geometry><box size="0.04 0.01 0.04"/></geometry>
      <material name="green"><color rgba="0.2 0.8 0.2 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.02"/>
      <geometry><box size="0.04 0.01 0.04"/></geometry>
    </collision>
  </link>

</robot>
